! Generated by Ansible — do not edit manually
! Host: {{ inventory_hostname }} | State: {{ keepalived_state }} | Priority: {{ keepalived_priority }}

global_defs {
    router_id {{ inventory_hostname }}
    script_user root
    enable_script_security
}

vrrp_script chk_postgresql {
    script "/bin/bash -c 'pg_isready -q -h 127.0.0.1 -p 5432'"
    interval {{ keepalived_check_interval }}
    rise    {{ keepalived_check_rise }}
    fall    {{ keepalived_check_fall }}
    weight  -20
}

vrrp_instance pg_ha {
    state     {{ keepalived_state }}
    interface {{ keepalived_interface }}
    virtual_router_id {{ keepalived_vrid }}
    priority  {{ keepalived_priority }}
    advert_int 1
    nopreempt

    authentication {
        auth_type PASS
        auth_pass {{ keepalived_auth_pass }}
    }

    virtual_ipaddress {
        {{ keepalived_vip }}/{{ keepalived_vip_prefix }} dev {{ keepalived_interface }}
    }

    track_script {
        chk_postgresql
    }
}
