[global]
# ---------------------------------------------------------------------------
# Repository — Azure Blob Storage
# ---------------------------------------------------------------------------
repo1-type={{ pgbackrest_repo_type }}
repo1-path={{ pgbackrest_repo_path }}
repo1-azure-account={{ pgbackrest_repo_azure_account }}
repo1-azure-key={{ pgbackrest_repo_azure_key }}
repo1-azure-container={{ pgbackrest_repo_azure_container }}

# Retention: keep {{ pgbackrest_retention_full }} full backups
repo1-retention-full={{ pgbackrest_retention_full }}

# Logging
log-level-console={{ pgbackrest_log_level_console }}
log-level-file={{ pgbackrest_log_level_file }}
log-path={{ pgbackrest_log_path }}

# Process slots
process-max={{ pgbackrest_process_max }}

[{{ pgbackrest_stanza }}]
pg1-path={{ pgbackrest_pg_path }}
